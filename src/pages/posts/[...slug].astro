---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { getCollection, render } from 'astro:content';
import { readingMinutes, primaryTag, wordCount, isoDate } from '../../lib/post.ts';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const tag = primaryTag(post.data.tags);
const minutes = readingMinutes(post.body);
const words = wordCount(post.body);
const date = isoDate(post.data.date);
const headerSlug = post.id.toUpperCase();

// Related: most recent other posts (max 3)
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 3);

const tocItems = headings.filter((h) => h.depth === 2);
---

<BaseLayout
  title={`${post.data.title} — K.Takata`}
  description={post.data.description}
  slug={headerSlug}
>
  <div class="breadcrumb">
    <a href={`${base}/posts`} class="back-link">← ls writing/</a>
    <span class="crumb-dim">/ {date} / {tag}</span>
  </div>

  <Section title="NAME">
    <h1 class="article-title">{post.data.title}</h1>
    <p class="article-summary">{post.data.description}</p>
    <div class="meta-row">
      <span class="meta-item"><span class="meta-key">date</span> {date}</span>
      <span class="meta-item"><span class="meta-key">tag</span> <span class="tag">{tag}</span></span>
      <span class="meta-item"><span class="meta-key">read</span> {minutes} min</span>
      <span class="meta-item"><span class="meta-key">words</span> ~ {words.toLocaleString()}</span>
    </div>
  </Section>

  {
    tocItems.length > 0 && (
      <Section title="CONTENTS">
        <ol class="toc">
          {tocItems.map((h, i) => (
            <li class="toc-item">
              <span class="toc-num">{String(i + 1).padStart(2, '0')}</span>
              <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
              <span class="toc-dots" />
              <span class="toc-anchor">§{h.slug}</span>
            </li>
          ))}
        </ol>
      </Section>
    )
  }

  <Section title="DESCRIPTION">
    <div class="prose-man">
      <Content />
    </div>
  </Section>

  {
    related.length > 0 && (
      <Section title="RELATED">
        {related.map((p) => (
          <a href={`${base}/posts/${p.id}`} class="rel-row">
            <span class="rel-date">{isoDate(p.data.date)}</span>
            <span class="rel-tag">{primaryTag(p.data.tags)}</span>
            <span class="rel-title">{p.data.title}</span>
            <span class="rel-arrow">→</span>
          </a>
        ))}
      </Section>
    )
  }

  <Section title="COLOPHON">
    <div class="colophon">
      最終更新 {date} · 訂正・指摘は <a href="https://github.com/KazumaTakata/" target="_blank" rel="noopener noreferrer">@ktakata</a> まで
    </div>
  </Section>
</BaseLayout>

<style>
  .rel-row {
    display: flex;
    gap: 14px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--rule);
    color: inherit;
    text-decoration: none;
    align-items: baseline;
    font-size: 12.5px;
  }
  .rel-row:hover .rel-title {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .rel-date {
    width: 100px;
    opacity: 0.6;
    font-size: 11px;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }
  .rel-tag {
    width: 90px;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
    flex-shrink: 0;
  }
  .rel-title {
    flex: 1;
    min-width: 0;
  }
  .rel-arrow {
    opacity: 0.5;
    flex-shrink: 0;
  }
  .colophon a {
    color: inherit;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
  }
  .colophon a:hover {
    color: var(--fg);
  }

  @media (max-width: 640px) {
    .rel-row {
      flex-wrap: wrap;
    }
    .rel-date,
    .rel-tag {
      width: auto;
    }
    .rel-title {
      flex-basis: 100%;
      margin-top: 4px;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import PostRow from '../components/PostRow.astro';
import { getCollection } from 'astro:content';
import { readingMinutes, primaryTag, isoDate } from '../lib/post.ts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const recentPosts = allPosts.slice(0, 6);
const lastDate = allPosts[0] ? isoDate(allPosts[0].data.date) : '';

const SITE = {
  name: 'K.Takata',
  role: 'エンジニア',
  location: 'Tokyo, JP',
  handle: '@ktakata',
  bio: [
    '東京を拠点に Web / 動画配信システム周りを書いているエンジニア。',
    'フロントエンドからバックエンド・インフラまで広く触り、最近は動画コーデックや配信品質の話に関心がある。',
    'ここは作業ログ・読書メモ・技術的な走り書きの置き場所。',
  ],
};
---

<BaseLayout title="K.Takata — index">
  <Section title="NAME">
    <div>{SITE.name} — {SITE.role} ({SITE.location})</div>
  </Section>

  <Section title="DESCRIPTION">
    {SITE.bio.map((l) => <div>{l}</div>)}
  </Section>

  <Section title="WRITING">
    <div class="table-head">
      <span style="width:110px">DATE</span>
      <span style="width:90px">TAG</span>
      <span style="width:50px">MIN</span>
      <span style="flex:1">TITLE</span>
    </div>
    {
      recentPosts.map((post) => (
        <PostRow
          date={post.data.date}
          tag={primaryTag(post.data.tags)}
          minutes={readingMinutes(post.body)}
          title={post.data.title}
          summary={post.data.description}
          href={`${base}/posts/${post.id}`}
        />
      ))
    }
    {
      allPosts.length > recentPosts.length && (
        <div class="see-more">
          <a href={`${base}/posts`}>→ ls writing/ ({allPosts.length} entries)</a>
        </div>
      )
    }
  </Section>

  <Section title="SEE ALSO">
    <div>
      <a href={`${base}/about`}>about(7)</a>
      &nbsp;·&nbsp;
      <a href="https://github.com/KazumaTakata/" target="_blank" rel="noopener noreferrer">github</a>
      &nbsp;·&nbsp;
      <span class="dim-text">last modified · {lastDate}</span>
    </div>
  </Section>
</BaseLayout>

<style>
  .see-more {
    margin-top: 14px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .see-more a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
  }
  .see-more a:hover {
    color: var(--fg);
  }
  .dim-text {
    color: var(--dim);
  }
</style>

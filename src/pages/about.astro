---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";

const skills = [
  {
    category: "Frontend",
    items: ["TypeScript", "React", "CSS"],
  },
  {
    category: "Backend",
    items: ["Node.js", "TypeScript", "Go", "Python", "RDB", "Firestore"],
  },
  {
    category: "DevOps",
    items: ["Google Cloud", "AWS", "GitHub Actions", "Terraform"],
  },
  {
    category: "Other",
    items: ["Video Streaming Technology", "Git"],
  },
];

const career = [
  {
    period: "2023 - Present",
    role: "ソフトウェアエンジニア",
    company: "Example Corp.",
    description:
      "Web アプリケーションの設計・開発を担当。フロントエンドからバックエンドまで幅広く携わる。",
  },
  {
    period: "2021 - 2023",
    role: "フロントエンドエンジニア",
    company: "Startup Inc.",
    description:
      "React / TypeScript を用いた SPA 開発。デザインシステムの構築にも貢献。",
  },
];
---

<BaseLayout title="About - K.Takata">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <!-- Profile -->
    <div class="fade-in">
      <SectionHeading title="About" subtitle="自己紹介" />
      <div class="space-y-4 text-dark-300 leading-relaxed">
        <p>
          ソフトウェアエンジニアとして、Web 技術を中心に開発に取り組んでいます。
        </p>
        <p>
          フロントエンドからバックエンド、インフラまで幅広い領域に興味があり、
          常に新しい技術を学び続けています。
        </p>
      </div>
    </div>

    <!-- Skills -->
    <div class="fade-in mt-20">
      <h2 class="text-2xl font-semibold text-white mb-8">Skills</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {
          skills.map((group) => (
            <div class="card">
              <h3 class="text-sm font-medium text-accent-400 uppercase tracking-wider mb-3">
                {group.category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="text-sm px-3 py-1 rounded-full bg-dark-800 text-dark-200">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

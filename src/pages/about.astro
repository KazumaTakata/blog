---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const skills = [
  { category: 'Frontend', items: ['TypeScript', 'React', 'CSS'] },
  { category: 'Backend',  items: ['Node.js', 'TypeScript', 'Go', 'Python', 'RDB', 'Firestore'] },
  { category: 'DevOps',   items: ['Google Cloud', 'AWS', 'GitHub Actions', 'Terraform'] },
  { category: 'Other',    items: ['Video Streaming Technology', 'Git'] },
];
---

<BaseLayout title="K.Takata — about" slug="about">
  <Section title="NAME">
    <div>K.Takata — エンジニア (Tokyo, JP)</div>
  </Section>

  <Section title="DESCRIPTION">
    <div>ソフトウェアエンジニアとして、Web 技術を中心に開発に取り組んでいる。</div>
    <div>フロントエンドからバックエンド、インフラまで幅広い領域に興味があり、最近は動画配信周りに関心が向いている。</div>
  </Section>

  <Section title="SKILLS">
    {
      skills.map((g) => (
        <div class="skill-row">
          <span class="skill-key">{g.category}</span>
          <span class="skill-items">
            {g.items.map((it, i) => (
              <>
                {i > 0 && <span class="sep">·</span>}
                <span>{it}</span>
              </>
            ))}
          </span>
        </div>
      ))
    }
  </Section>

  <Section title="SEE ALSO">
    <div>
      <a href="https://github.com/KazumaTakata/" target="_blank" rel="noopener noreferrer">github.com/KazumaTakata</a>
    </div>
  </Section>
</BaseLayout>

<style>
  .skill-row {
    display: flex;
    gap: 14px;
    padding: 6px 0;
    border-bottom: 1px dashed var(--rule);
    align-items: baseline;
    flex-wrap: wrap;
  }
  .skill-key {
    width: 130px;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    flex-shrink: 0;
  }
  .skill-items {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .sep {
    opacity: 0.4;
  }

  a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
  }
  a:hover {
    color: var(--fg);
  }
</style>

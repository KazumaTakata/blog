---
interface Props {
  slug?: string;
}

const { slug } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const navItems = [
  { label: 'index', href: `${base}` || '/' },
  { label: 'writing', href: `${base}/posts` },
  { label: 'about', href: `${base}/about` },
];

const center = (slug ?? '個人サイト').toUpperCase();
---

<header role="banner">
  <div class="strip">
    <span class="strip-left">KTAKATA(1)</span>
    <span class="strip-center" aria-hidden="true">{center}</span>
    <span class="strip-actions">
      <button id="theme-toggle" type="button" aria-label="ライト・ダークテーマを切り替え">[ THEME ]</button>
    </span>
  </div>

  <nav class="nav" aria-label="サイトナビゲーション">
    {
      navItems.map((item, i) => {
        const itemPath = item.href.replace(/\/$/, '');
        const isActive =
          item.label === 'index'
            ? currentPath === itemPath || currentPath === ''
            : currentPath.startsWith(itemPath) && itemPath !== '';
        return (
          <>
            {i > 0 && <span class="nav-sep" aria-hidden="true">·</span>}
            <a
              href={item.href}
              class:list={['nav-link', { active: isActive }]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          </>
        );
      })
    }
  </nav>
</header>

<style>
  .strip-left {
    flex-shrink: 0;
  }

  .strip-center {
    text-align: center;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .strip-actions {
    text-align: right;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .strip-center {
      display: none;
    }
  }

  .strip-actions button {
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    letter-spacing: inherit;
    cursor: pointer;
    padding: 6px 4px;
    min-height: 32px;
  }

  .strip-actions button:hover {
    color: var(--fg);
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: baseline;
    margin-bottom: 36px;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }

  @media (max-width: 640px) {
    .nav {
      margin-bottom: 24px;
      letter-spacing: 0.12em;
    }
  }

  .nav-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding: 6px 2px 5px;
    transition: color 0.15s, border-color 0.15s;
  }

  .nav-link:hover {
    color: var(--fg);
  }

  .nav-link.active {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  .nav-sep {
    opacity: 0.5;
  }
</style>

<script is:inline>
  (function () {
    function setTheme(dark) {
      if (dark) {
        document.documentElement.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      }
    }
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      setTheme(!isDark);
    });
  })();
</script>

---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12">
  <h2 class="text-3xl md:text-4xl font-semibold text-dark-950 dark:text-white">{title}</h2>
  {subtitle && <p class="mt-3 text-dark-800 dark:text-dark-400 text-lg">{subtitle}</p>}
</div>

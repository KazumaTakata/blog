---
interface Props {
  title: string;
  description: string;
  tags: string[];
  url?: string;
  github?: string;
}

const { title, description, tags, url, github } = Astro.props;
---

<div class="card group">
  <h3 class="text-lg font-semibold text-white group-hover:text-accent-400 transition-colors duration-200">
    {title}
  </h3>
  <p class="mt-2 text-sm text-dark-400 leading-relaxed">{description}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs px-2.5 py-1 rounded-full bg-dark-800 text-dark-300">
        {tag}
      </span>
    ))}
  </div>
  {(url || github) && (
    <div class="mt-4 flex gap-4">
      {url && (
        <a href={url} target="_blank" rel="noopener noreferrer" class="text-sm text-accent-400 hover:text-accent-300 transition-colors">
          Live Demo &rarr;
        </a>
      )}
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" class="text-sm text-dark-400 hover:text-white transition-colors">
          GitHub
        </a>
      )}
    </div>
  )}
</div>
